# --- WorkOS AuthKit (login lives in the web tier) ---
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# 32+ char secret for sealing the session cookie. openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=
# Must match a redirect URI registered in WorkOS and the /callback route.
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Where the NestJS api lives (the /app page calls it server-side).
API_BASE_URL=http://localhost:3001

# Database — only used by /demo (which talks to Prisma directly).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegis
