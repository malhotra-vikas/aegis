# --- Database (Prisma) ---
# aegis_app is the least-privilege RLS role. Locally you can point both at the
# owner connection (RLS is bypassed for the owner — fine for dev/demo).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegis
# APP_DATABASE_URL=postgresql://aegis_app:CHANGE_ME@localhost:5432/aegis

# --- Envelope master key (credential encryption) ---
# 32 random bytes, base64. Generate: openssl rand -base64 32
AEGIS_MASTER_KEY=
AEGIS_MASTER_KEY_VERSION=1

# --- Meta OAuth (read-only) — from your Meta dev app ---
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:3001/oauth/meta/callback
# META_GRAPH_VERSION=v21.0
# META_OAUTH_SCOPES=ads_read,business_management

# --- WorkOS (api verifies access tokens) ---
# CLIENT_ID is required to build the JWKS URL.
WORKOS_CLIENT_ID=
# WORKOS_JWKS_URL=  # default: https://api.workos.com/sso/jwks/<client_id>
# WORKOS_ISSUER=    # recommended once known, to pin the token issuer

# --- Local only: bypass auth, scope every request to this org (NEVER in prod) ---
# AEGIS_DEV_ORG_ID=
